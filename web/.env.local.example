# Chain to target: 4663 (Robinhood mainnet), 46630 (testnet), or 31337 (local hardhat)
NEXT_PUBLIC_CHAIN_ID=46630

# Deployed contract addresses (from `npm run deploy:*` in ../contracts)
NEXT_PUBLIC_LAUNCHPAD_FACTORY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PUMPSWAP_FACTORY=0x0000000000000000000000000000000000000000

# Flagship / platform token (the default first token to ape)
NEXT_PUBLIC_PLATFORM_TOKEN=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PLATFORM_PAIR=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TREASURY=0x0000000000000000000000000000000000000000

# WalletConnect project id — required for mobile / QR wallet connections.
# Get a free one at https://cloud.walletconnect.com
# If unset, only browser-extension wallets (MetaMask, etc.) are offered.
NEXT_PUBLIC_WALLETCONNECT_ID=

# Backend indexer API (optional — enables charts, trade history, USD stats)
# Local: http://localhost:3001  Production: your deployed backend URL
NEXT_PUBLIC_API_URL=

# Token image uploads (required on Vercel production; auto-created when you add Blob storage)
# Local dev writes to public/uploads/ without this.
BLOB_READ_WRITE_TOKEN=

# Public site URL used for local upload links (optional; defaults to request host)
NEXT_PUBLIC_SITE_URL=

# Uniswap v2-compatible DEX for graduated-token trading.
# On Robinhood mainnet (4663) these default to the canonical RH Chain Uniswap v2
# deployment if left blank — see HANDOFF.md.
#   router  0x89e5db8b5aa49aa85ac63f691524311aeb649eba
#   factory 0x8bceaa40b9acdfaedf85adf4ff01f5ad6517937f
#   weth    0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73
NEXT_PUBLIC_DEX_ROUTER=
NEXT_PUBLIC_DEX_FACTORY=
NEXT_PUBLIC_WETH=
