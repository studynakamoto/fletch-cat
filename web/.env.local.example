# Chain to target: 4663 (Robinhood mainnet), 46630 (testnet), or 31337 (local hardhat)
NEXT_PUBLIC_CHAIN_ID=46630

# Deployed contract addresses (from `npm run deploy:*` in ../contracts)
NEXT_PUBLIC_LAUNCHPAD_FACTORY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PUMPSWAP_FACTORY=0x0000000000000000000000000000000000000000

# Flagship / platform token (the default first token to ape)
NEXT_PUBLIC_PLATFORM_TOKEN=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PLATFORM_PAIR=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TREASURY=0x0000000000000000000000000000000000000000

# WalletConnect project id (optional; get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_ID=

# Backend indexer API (optional — enables charts, trade history, USD stats)
# Local: http://localhost:3001  Production: your deployed backend URL
NEXT_PUBLIC_API_URL=
