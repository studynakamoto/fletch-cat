# Deployer private key (no 0x prefix is fine too). NEVER commit your real key.
PRIVATE_KEY=

# RPC overrides (optional; defaults point at Robinhood Chain public RPCs)
RH_RPC_URL=https://rpc.mainnet.chain.robinhood.com
RH_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com

# Treasury wallet — graduation fees accumulate here; run buybacks from this key
FEE_RECIPIENT=

# Platform token defaults (optional — deploy.ts defaults to fletch.cat / FLETCH)
# PLATFORM_NAME=fletch.cat
# PLATFORM_SYMBOL=FLETCH
# PLATFORM_LP_ETH=0.1

# Platform token (defaults: Fletch Cat / FLETCH)
PLATFORM_NAME=Fletch Cat
PLATFORM_SYMBOL=FLETCH
